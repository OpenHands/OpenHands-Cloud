{
  "name": "integrations-hub",
  "namespace": "pr862-pr",
  "image": "localhost:5001/integrations-hub:evidence-6dd4851",
  "probes": {
    "startup": {
      "failureThreshold": 30,
      "httpGet": {
        "path": "/api/live",
        "port": 8000,
        "scheme": "HTTP"
      },
      "periodSeconds": 10,
      "successThreshold": 1,
      "timeoutSeconds": 2
    },
    "liveness": {
      "failureThreshold": 3,
      "httpGet": {
        "path": "/api/live",
        "port": 8000,
        "scheme": "HTTP"
      },
      "initialDelaySeconds": 10,
      "periodSeconds": 30,
      "successThreshold": 1,
      "timeoutSeconds": 2
    },
    "readiness": {
      "failureThreshold": 3,
      "httpGet": {
        "path": "/api/ready",
        "port": 8000,
        "scheme": "HTTP"
      },
      "initialDelaySeconds": 5,
      "periodSeconds": 10,
      "successThreshold": 1,
      "timeoutSeconds": 2
    }
  },
  "datadogAndLogEnv": [
    {
      "name": "DD_AGENT_HOST",
      "value": "datadog-agent.all-hands-system.svc.cluster.local"
    },
    {
      "name": "DD_TRACE_AGENT_PORT",
      "value": "8126"
    },
    {
      "name": "DD_DOGSTATSD_PORT",
      "value": "8125"
    },
    {
      "name": "DD_SERVICE",
      "value": "integrations-hub"
    },
    {
      "name": "DD_ENV",
      "value": "evidence"
    },
    {
      "name": "DD_VERSION",
      "value": "evidence-6dd4851"
    },
    {
      "name": "DD_LOGS_INJECTION",
      "value": "true"
    },
    {
      "name": "DD_TRACE_ENABLED",
      "value": "true"
    },
    {
      "name": "DD_TRACE_SAMPLING_RULES",
      "value": "[{\"resource\":\"GET /api/health\",\"sample_rate\":0.0},{\"resource\":\"GET /api/live\",\"sample_rate\":0.0},{\"resource\":\"GET /api/ready\",\"sample_rate\":0.0}]"
    },
    {
      "name": "LOG_JSON",
      "value": "1"
    },
    {
      "name": "LOG_JSON_LEVEL_KEY",
      "value": "severity"
    }
  ]
}
